---
import { Card, CardGrid, LinkCard } from "@astrojs/starlight/components";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { AMLLPreview } from "../../components/AMLLPreview";
import "../../styles/index.css";
---

<StarlightPage
	frontmatter={({
		title: "AppleMusic-like Lyrics",
		description: "A lyrics player component library built for the web",
		template: "splash",
	})}
	lang="en"
>
	<div style="height: max(400px, 50vh);">
		<style scoped>
		:root[data-theme="light"] {
			--amll-lp-color: black;
		}
		</style>
		<AMLLPreview client:only="react" />
	</div>
	<Card title="Get Started with AppleMusic-like Lyrics" icon="open-book">
		<p>Use the links below to start reading the documentation.</p>
		<CardGrid>
			<LinkCard
				title="Introduction"
				description="Basic information about AMLL"
				href="/en/guides/overview/intro"
			/>
			<LinkCard
				title="Quick Start"
				description="Integrate AMLL lyric components into your project"
				href="/en/guides/overview/quickstart"
			/>
			<LinkCard
				title="Ecosystem"
				description="AMLL related projects and development"
				href="/en/guides/overview/eco"
			/>
			<LinkCard
				title="API Reference"
				description="API docs for each package"
				href="/en/reference"
			/>
			<LinkCard
				title="Contributing"
				description="How to participate in AMLL development and maintenance"
				href="/en/contribute"
			/>
		</CardGrid>
	</Card>
</StarlightPage>
